# ── Smart Office Monitor — Environment Configuration ──────────────────────────
# Copy this file to `.env` and fill in values as needed.

# Discord Bot (leave blank to run without Discord integration)
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_COMMAND_PREFIX=!

# Simulation speed (seconds between random device toggles)
SIM_MIN_INTERVAL=3
SIM_MAX_INTERVAL=8

# Office hours (24-hour format)
OFFICE_HOURS_START=9
OFFICE_HOURS_END=17

# Long-running room alert threshold in seconds (default 2 hours = 7200)
# Set to a low value (e.g., 30) for quick demo verification
ALERT_LONG_RUNNING_THRESHOLD_SECONDS=7200
